APP_URL=http://localhost/Case-study-QLPT/public

# SePay bank transfer settings
SEPAY_BANK_NAME=Vietcombank
SEPAY_BANK_ACCOUNT=0010000000355
SEPAY_BANK_ACCOUNT_NAME=NGUYEN VAN A

# If your existing env uses VietQR names, these are also supported:
# VIETQR_BANK_BIN=970422
# VIETQR_BANK_NAME=MB Bank
# VIETQR_ACCOUNT_NO=0123456789
# VIETQR_ACCOUNT_NAME=NGUYEN VAN A

# Use one of SePay webhook auth methods. API Key is the simplest for this PHP app.
# In SePay dashboard, choose API Key authentication and paste the same value.
SEPAY_WEBHOOK_API_KEY=change-me

# Optional: set if you later use SePay user API reconciliation.
SEPAY_API_TOKEN=
